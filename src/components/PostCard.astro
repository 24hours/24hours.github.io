---
import type { Post } from '../utils/posts';
import { postUrl } from '../utils/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const url = postUrl(post);
const dateTime = post.data.originalPublished ?? post.data.date.toISOString();
const day = String(post.data.date.getDate()).padStart(2, '0');
const month = String(post.data.date.getMonth() + 1).padStart(2, '0');
const year = post.data.date.getFullYear();
const dateStr = `${day}.${month}.${year}`;
---

<article class="post-list-item">
  <div class="post-list-meta-line">
    <time class="meta-date-wrapper" datetime={dateTime}>{dateStr}</time>
    <h2 class="post-title">
      <a href={url} class="post-title-link">{post.data.title}</a>
    </h2>
  </div>
</article>
